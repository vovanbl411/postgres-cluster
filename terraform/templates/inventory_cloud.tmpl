[bastion]
bastion-host ansible_host=${bastion_ip}

[bastion:vars]
ansible_user=root
wg_tunnel_ip=10.200.0.1

[postgres_nodes]
%{ for index, ip in pg_ips ~}
pg-node-${index + 1} ansible_host=${ip}
%{ endfor ~}

[postgres_nodes:vars]
ansible_user=root
ansible_ssh_common_args='-o ProxyJump=root@${bastion_ip}'